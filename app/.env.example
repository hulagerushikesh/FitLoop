# Copy this file to .env and fill in your Supabase project credentials.
# Find these in your Supabase project: Settings -> API
# EXPO_PUBLIC_ vars are inlined into the client bundle at build time —
# only put values here that are safe to ship to a device (the anon key
# is designed for this; access is enforced by Postgres RLS policies).
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
